# =============================================================================
# 배포 변수 — 실제 사용 시 .env.deploy 로 복사 후 값 채우기
#   cp .env.deploy.example .env.deploy
#   set -a; source .env.deploy; set +a
#
# .env.deploy 는 git 에 커밋하지 말 것 (.gitignore 에 추가).
# =============================================================================

# ---- Harbor (HTTP MVP) ----
# HTTPS 전환 시 도메인으로 변경하고 docs/HTTPS_MIGRATION.md 의 절차 수행.
HARBOR_URL=210.109.53.140
HARBOR_PROJECT=agami
HARBOR_USER=admin
HARBOR_PASSWORD=__set_me__

# ---- 이미지 태그 ----
# 운영 권장: latest 금지, semver 또는 git short sha 사용.
VERSION=v0.1.0

# ---- 외부 노출 주소 (Bastion) ----
# CORS_ORIGINS 와 seed.sql 의 allowed_origins 에 들어가야 함.
PUBLIC_URL=http://210.109.53.140

# ---- DB 비밀번호 (postgres-secret 으로 들어감) ----
# MVP 기본값 'captcha' 와 일치시키지 않는다면 backend-configmap.yaml 의 DATABASE_URL
# 도 함께 수정 후 redeploy 필요.
POSTGRES_PASSWORD=captcha

# ---- API 비밀 (captcha-api-secrets 으로 들어감) ----
# 운영에서는 openssl rand -hex 32 로 생성한 값 사용. 절대 default 금지.
API_KEY_HMAC_PEPPER=__set_me_hex32__
CAPTCHA_TOKEN_SECRET=__set_me_hex32__
