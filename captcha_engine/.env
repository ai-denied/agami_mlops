# =============================================================================
# Captcha Engine — Local development environment variables
# =============================================================================
# 사용법:
#   cp .env.example .env  # 그대로 사용 가능 (로컬 한정)
# 운영 배포 시 모든 *_SECRET / PEPPER 값은 반드시 교체 + KMS/Secret Manager 사용.
# =============================================================================

# 일반
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL (docker-compose 의 db 서비스 기준)
# 로컬에서 직접 띄운 PG 라면 host=localhost 로 변경.
DATABASE_URL=postgresql+asyncpg://captcha_user:securepassword@db:5432/captcha_db

# Redis (docker-compose 의 redis 서비스 기준)
REDIS_URL=redis://redis:6379/0

# 보안 — 시드 SQL 의 sk_test 해시는 아래 두 값 기준으로 계산되어 있음.
# 값을 바꾸면 seed.sql 도 다시 계산해서 갱신해야 함.
API_KEY_HMAC_PEPPER=local-pepper-do-not-use-in-prod
CAPTCHA_TOKEN_SECRET=local-token-secret-do-not-use-in-prod

# 캡챠 동작 정책 기본값
DEFAULT_DIFFICULTY=medium
DEFAULT_RATE_LIMIT_PER_MIN=60
